.window {
	--window-background: #C0C0C0;
	padding: 2px;
	background-color: 1px;
	background-color: var(--window-background);
	border: 2px;
	--border-c1: rgb(251, 251, 251);
	--border-c2: rgb(97, 97, 97);
	border-color: var(--border-c1) var(--border-c2) var(--border-c2) var(--border-c1);
	border-style: groove ridge ridge groove;
}

.window-content {
	font-size: 12px;
	display: flex;
	/* flex-wrap: wrap; */
	flex-direction: column;
	background-color: var(--window-background);
	font-weight: 100;
}

.border-style-light-1 {
	border: 2px;
	--border-c1: rgb(238, 238, 238);
	--border-c2: rgb(170, 170, 170);
	border-color: var(--border-c1) var(--border-c1) var(--border-c1) var(--border-c1);
	border-style: groove groove groove groove;
}

.menubar {
	padding: 2px;
	padding-left: 10px;
	display: flex;
	column-gap: 10px;
}

.menubar-item {
	
}

.menubar-item::first-letter {
	text-decoration: underline;
}

.fe-address-bar {
	padding: 0 2px;
	display: flex;
	column-gap: 2px;
	align-items: center;
	border-top: none;
}

.fe-address-bar p:nth-child(1) {}

.fe-address-bar p:nth-child(2) {
	background-color: white;
	flex-grow: 1;
}

.border-style-dark-1 {
	border: 2px;
	--border-c1: rgb(97, 97, 97);
	--border-c2: rgb(251, 251, 251);
	border-color: var(--border-c1) var(--border-c2) var(--border-c2) var(--border-c1);
	border-style: ridge groove groove ridge;
}

.window-main {
	padding-top: 3px;
	flex-grow: 1;
	display: flex;
	flex-direction: column;
}

.fe-main {
	display: flex;
	flex-grow: 1;
	column-gap: 2px;
}

.fe-view {
	/* TODO: remove if favor of transforms? */
	position: relative;
	flex-grow: 1;
	background-color: white;
}

.fe-view p {
	color: black;
}

.fe-sideview {
	width: 100px;
	display: flex;
	flex-direction: column;
	position: relative;
	/* height: 100%; */
}

.fe-sideview-header {
	border: 2px;
	--border-c1: rgb(238, 238, 238);
	--border-c2: rgb(170, 170, 170);
	border-color: var(--border-c1) var(--border-c1) var(--border-c1) var(--border-c1);
	border-style: none none groove none;
	padding: 2px;
	padding-left: 6px;
	z-index: 1;
	background-color: var(--window-background);
}

.fe-sideview-view {
	background-color: white;
	flex-grow: 1;
	z-index: 0;
	/* padding-left: 20px; */
}
.fe-svv-child {
	/* border-left: 1px dotted black; */
	padding-left: 0px;
	position: relative;
	left: 14px;
	z-index: 0;
}
.fe-svv-child::before {
	content: "";
	position: absolute;
	border-left: 1px dotted black;
	height: 100%;
	transform: translate(-1px, -3px);
	z-index: -1;
}
.fe-svv-item {

}
.fe-svvi-icon {
	background: url("https://win98icons.alexmeub.com/icons/png/directory_closed-4.png");
	background-size: cover;
	width: 14px;
	height: 14px;
	z-index: 1;
}
.fe-svvi-group {
	display: flex;
	align-items: center;
}
.fe-svvi-expander {
	width: 8px;
	height: 8px;
	border: 0.5px solid black;
	background-color: white;
	position: absolute;
	transform: translateX(-5px);
	/* left: -5px; */
}
.fe-svvi-line {
	width: 9px;
	height: 0px;
	border-bottom: 1px dotted black;
	transform: translateX(-1px);
	z-index: -1;
	/* left: -5px; */
}
.fe-svvi-group p {
	margin-left: 5px;
}
.fe-sideview-view {
	overflow: scroll;
}

.fe-sideview-view::-webkit-scrollbar {
	height: 10px;
}
.fe-sideview-view::-webkit-scrollbar:vertical {
	width: 10px;
}

.fe-sideview-view::-webkit-scrollbar-track {
	background: #C0C0C0;
}

/* Handle */
.fe-sideview-view::-webkit-scrollbar-thumb {
	background: #888;
}

/* Handle on hover */
.fe-sideview-view::-webkit-scrollbar-thumb:hover {
	background: #555;
}

.fe-sideview::after {
	content: "";
	width: 10px;
	height: 10px;
	background-color: #C0C0C0;
	display: block;
	position: absolute;
	bottom: 0;
	right: 0;
}